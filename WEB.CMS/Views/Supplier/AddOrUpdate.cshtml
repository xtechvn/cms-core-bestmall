@{
    Layout = null;
    List<AttachFile> Attachment_Root = (List<AttachFile>)ViewBag.Attachment_Root;
    List<AttachFile> Attachment_Product = (List<AttachFile>)ViewBag.Attachment_Product;
    List<AttachFile> Attachment_Supply = (List<AttachFile>)ViewBag.Attachment_Supply;
    List<AttachFile> Attachment_Confirm = (List<AttachFile>)ViewBag.Attachment_Confirm;
    bool has_permission= (bool)ViewBag.HaveValidatePermission;
}
@using Entities.Models
@using Entities.ViewModels.Funding
@using Utilities.Contants
@model SupplierViewModel

<form id="form_supplier">
    <div class="row row_min">
        <div class="grid-item col-md-12 @*@(Model.SupplierId > 0 ? " col-md-12" : "col-md-6" )*@">
            <div class="border mb20">
                <div class="lb-form">Thông tin cơ bản</div>
                <div class="pd10">
                    <div class="form-group">
                        <label class="lbl">Tên nhà cung cấp <sup class="red">*</sup></label>
                        <div class="wrap_input">
                            <input type="hidden" asp-for="@Model.SupplierId" />
                            <input type="text" class="form-control" asp-for="@Model.FullName" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="lbl">Điện thoại</label>
                        <div class="wrap_input">
                            <input type="text" class="form-control" asp-for="@Model.Phone" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="lbl">Email <sup class="red">*</sup></label>
                        <div class="wrap_input">
                            <input type="text" class="form-control" asp-for="@Model.Email" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="lbl">Địa chỉ</label>
                        <div class="wrap_input">
                            <input type="text" class="form-control" asp-for="@Model.Address" />
                        </div>
                    </div>
                   
                </div>
            </div>
        </div>
        <div class="grid-item col-md-12">
