                                        <div class="col-sm-3 col-4 mb10 file" style="max-width:150px;" data-path="@item.Path" data-id="@item.Id" data-ext="@item.Ext">
                                            <button type="button" class="delete-file" onclick="$(this).closest('.file').remove()"
