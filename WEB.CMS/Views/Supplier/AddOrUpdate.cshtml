</form>
<div class="row row_min">
    <div class="grid-item text-left col-md-6">
        @if (Model.SupplierId > 0)
        {
            @if (has_permission && (Model.Status == null || Model.Status == (int)SUPPLIER_STATUS.ON_WAITING_CONFIRMATION))
            {
                <button type="button" class="btn btn-default" onclick="_supplier_service.ValidateSupplier(@Model.SupplierId, @((int)SUPPLIER_STATUS.CONFIRMED))">Duyệt NCC</button>
            }
            @if (has_permission && (Model.Status == (int)SUPPLIER_STATUS.CONFIRMED))
            {
                <button type="button" class="btn btn-default" onclick="_supplier_service.ValidateSupplier(@Model.SupplierId,@((int)SUPPLIER_STATUS.ON_WAITING_CONFIRMATION))">Bỏ duyệt NCC</button>
            }
            @if (has_permission && (Model.Status != (int)SUPPLIER_STATUS.DELETED))
            {
                <button type="button" class="btn btn-default" onclick="_supplier_service.ValidateSupplier(@Model.SupplierId,@((int)SUPPLIER_STATUS.DELETED))">Xóa NCC</button>
            }
        }

    </div>
    <div class=" grid-item text-right col-md-6">

        <button type="button" class="btn btn-default btn btn-default cancel" data-dismiss="modal">Bỏ qua</button>
        @if (Model.SupplierId > 0)
        {
            <button type="button" class="btn btn-default" onclick="_supplier_service.OnAdd()">Cập nhật</button>

        }
        else
        {
            <button type="button" class="btn btn-default" onclick="_supplier_service.OnAdd()">Thêm mới</button>
        }

    </div>

</div>
