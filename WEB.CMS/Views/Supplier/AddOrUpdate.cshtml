@{
    Layout = null;
    List<AttachFile> attachfiles = (List<AttachFile>)ViewBag.Attachment;
}
@using Entities.Models
@using Entities.ViewModels.Funding
@model SupplierViewModel

<form id="form_supplier">
    <div class="row row_min">
        <div class="grid-item @(Model.SupplierId > 0 ? "col-md-12" : "col-md-6")">
            <div class="border mb20">
                <div class="lb-form">Thông tin cơ bản</div>
                <div class="pd10">
                    <div class="form-group">
                        <label class="lbl">Tên nhà cung cấp <sup class="red">*</sup></label>
                        <div class="wrap_input">
                            <input type="hidden" asp-for="@Model.SupplierId" />
                            <input type="text" class="form-control" asp-for="@Model.FullName" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="lbl">Điện thoại</label>
                        <div class="wrap_input">
                            <input type="text" class="form-control" asp-for="@Model.Phone" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="lbl">Email</label>
                        <div class="wrap_input">
                            <input type="text" class="form-control" asp-for="@Model.Email" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="lbl">Địa chỉ</label>
                        <div class="wrap_input">
                            <input type="text" class="form-control" asp-for="@Model.Address" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="lbl">Chứng chỉ kinh doanh <sup class="red">*</sup></label>
                        <div class="wrap_input">
                            <div id="supplier-attachfile-list" class="row list-choose lightgallery attachment-file-gallery">
                                @if(attachfiles!=null && attachfiles.Count > 0)
                                {
                                    foreach(var item in attachfiles)
                                    {
                                        <div class="col-sm-3 col-4 mb10 file" style="max-width:150px;" data-path="@item.Path" data-id="@item.Id" data-ext="@item.Ext">
                                            <button type="button" class="delete-file" onclick="$(this).closest('.file').remove()"
                                                    style=" background: #ED5C6A; color: #fff; position: absolute; right: -7px; top: -7px; z-index: 2; border: 0; width: 20px; height: 20px; border-radius: 50%; outline: 0; cursor: pointer; ">
                                                x
                                            </button>
                                            <div class="choose-ava lightgallery">
                                                <img src="@item.Path" />
                                            </div>
                                            <p style=" overflow: hidden; "><span>@item.Path</span> </p>
                                        </div>
                                    }
                                }
                            </div>
                            <div class="manage-color  w-100" style="max-height:200px;">
                                <div class="flex list align-items-center w-100">
                                    <div class="flex align-center pd10 mb20">
                                        <label class="choose mb0" style="width: 100% !important;">
                                            <input id="supplier-attachfile" type="file" class="attachfile-add" multiple style="display: none;">
                                            <a class="btn-default" href="javascript:;" onclick="$(this).closest('.choose').find('.attachfile-add').trigger('click')" style="color: #fff;cursor: pointer; margin-top:10px;">
                                                <i class="fa fa-upload"></i>&nbsp;&nbsp;Upload file
                                            </a>

                                        </label>
                                        <div class="gray txt_12" style="margin-top: 10px; width: 100% !important;">
                                            <p style="margin-left: 3px;">Upload nhiều file cùng lúc. Định dạng: .jpg,.png,.jpeg, .gif. Dung lượng tối đa 5Mb.</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        @if (Model.SupplierId == 0)
        {
            <div class="grid-item col-md-6">
                <div class="border mb20">
                    <div class="lb-form">Thông tin liên hệ</div>
                    <div class="pd10">
                        <div class="form-group">
                            <label class="lbl">Họ tên</label>
                            <div class="wrap_input">
                                <input type="text" class="form-control" name="ContactName" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="lbl">Điện thoại</label>
                            <div class="wrap_input">
                                <input type="text" class="form-control" name="ContactPhone" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="lbl">Email</label>
                            <div class="wrap_input">
                                <input type="text" class="form-control" name="ContactEmail" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="lbl">Chức vụ</label>
                            <div class="wrap_input">
                                <input type="text" class="form-control" name="ContactAddress" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="border mb20">
                    <div class="lb-form">Thông tin thanh toán</div>
                    <div class="pd10">
                        <div class="form-group">
                            <label class="lbl">Số tài khoản</label>
                            <div class="wrap_input">
                                <input type="text" class="form-control" name="BankAccountNumber" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="lbl">Chủ tài khoản</label>
                            <div class="wrap_input">
                                <input type="text" class="form-control" name="BankAccountName" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="lbl">Ngân hàng</label>
                            <div class="wrap_input">
                                <input type="text" class="form-control" name="BankId" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="lbl">Chi nhánh</label>
                            <div class="wrap_input">
                                <input type="text" class="form-control" name="BankBranch" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</form>

<div class="text-right">
    <button type="button" class="btn btn-default btn btn-default cancel" data-dismiss="modal">Bỏ qua</button>
    @if (Model.SupplierId > 0)
    {
        <button type="button" class="btn btn-default" onclick="_supplier_service.OnAdd()">Cập nhật</button>
    }
    else
    {
        <button type="button" class="btn btn-default" onclick="_supplier_service.OnAdd()">Thêm mới</button>
    }
</div>
