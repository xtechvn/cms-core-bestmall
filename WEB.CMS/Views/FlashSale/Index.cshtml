@using Entities.ViewModels
@{
    ViewData["Title"] = "FlashSale";
}
<div class="row-main container">
    <div class="bg-white px-2 mb-3">
        <div class="line-bottom mb-0" style="padding-bottom: 0;">
            <div class="tab-default mb0">
                <a href="#" class="active text-uppercase py-2">
                    Quản lý sản
                    phẩm
                </a>
                <a href="#" class="text-uppercase  py-2">Quản lý danh mục</a>
            </div>
        </div>
    </div>
    <div class="bg-white p-3 mb-3 tongquan">
        <div class="flex justify-content-between">
            <div>
                <h5 class="bold">Tổng quan FLASHSALE</h5>
                <div class="text-secondary">(Từ 08-09-2024 đến 09-04-2024 GMT+7)</div>
            </div>
            <a href="" class="text-primary">Xem thêm <i class="icofont-thin-right"></i></a>
        </div>

        <div class="row mt-3">
            <div class="col-lg-3 col-md-6">
                <div class="text-secondary">Doanh số<i class="icofont-question-circle ml-2"></i></div>
                <div class="number"><span class="mr-2">đ</span>0</div>
                <small class="text-secondary">so với 7 ngày trước <b>0%</b></small>
            </div>
            <div class="col-lg-3 col-md-6 border-left">
                <div class="text-secondary">Đơn hàng<i class="icofont-question-circle ml-2"></i></div>
                <div class="number">0</div>
                <small class="text-secondary">so với 7 ngày trước <b>0%</b></small>
            </div>
            <div class="col-lg-3 col-md-6 border-left">
                <div class="text-secondary">Người mua<i class="icofont-question-circle ml-2"></i></div>
                <div class="number">0</div>
                <small class="text-secondary">so với 7 ngày trước <b>0%</b></small>
            </div>
            <div class="col-lg-3 col-md-6 border-left">
                <div class="text-secondary">Tỉ lệ truy cập<i class="icofont-question-circle ml-2"></i></div>
                <div class="number">0</div>
                <small class="text-secondary">so với 7 ngày trước <b>0%</b></small>
            </div>
        </div>
    </div>
    <div class="bg-white p-3 mb-3">
        <div class="flex justify-content-between align-items-center mb-3">
            <div>
                <h5 class="bold">Danh sách chương trình</h5>
                <div class="text-secondary">Chạy chương trình flashsale để tăng doanh số</div>
            </div>
            <a href="" class="btn btn-add"><i class="icofont-plus"></i> Thêm</a>
        </div>
        <div class="flex gap10 align-items-center mb-3 left-button">
            <button class="btn btn-light btn-active">
                Tất cả
            </button>
            <button class="btn btn-light">
                Đang diễn ra
            </button>
            <button class="btn btn-light">
                Sắp diễn ra
            </button>
            <button class="btn btn-light">
                Đã kết thúc
            </button>
        </div>
        <div class="flex gap10 align-items-center mb-3">
            <label>Khung giờ</label>
            <div class="datetime">
                <i class="icofont-calendar"></i>
                <input class="form-control" placeholder="Chọn khung thời gian bạn muốn tìm kiếm">
            </div>
        </div>
        <div id="flashsale-data" class="wrap_bg wrap_bg_no-padding">
           
        </div>
    </div>
</div>
