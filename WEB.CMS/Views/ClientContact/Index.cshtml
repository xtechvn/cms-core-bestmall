@{
    ViewData["Title"] = "Thông tin khách hàng liên hệ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<section class="main-container main-products">
    <div class="row-main container bg-white">
        <div class="line-bottom" style="padding-bottom: 0;">
            <div class="tab-default mb0" data-tab-container="tab-container-1">
                <a href="#" class="active text-uppercase" data-lbl="danh-sach-phong">
                    Quản lý sản
                    phẩm
                </a>
                @*<a href="#" class="text-uppercase" data-lbl="chuong-trinh">Quản lý danh mục</a>*@
            </div>
        </div>

        <div class="flex gap10 flex-lg-nowrap">
            <div class="form-group w-100 ">
                <div class="search-wrapper">
                    <input id="client-contact-keyword" type="text" class="input_search  onclick-togle border" name="" value=""
                           placeholder="Email, số điện thoại, lời nhắn,...">
                    <span class="search-btn">
                        <button class="btn-search-product" type="submit">
                            <svg class="icon-svg">
                                <use xlink:href="images/icons/icon.svg#search"></use>
                            </svg>
                        </button>
                    </span>
                </div>
            </div>
           
            <div class="form-group">
                <button class="btn select-icon btn-round btn-outline-secondary btn-search-product">
                    <i class="icofont-search"></i>
                    Tìm kiếm
                </button>
            </div>
        </div>
        <div class="flex gap10 flex-lg-nowrap justify-content-between mb-3 align-items-center">
            <div class="flex gap10">
                <button class="btn btn-default mb10" type="button" onclick="_client_contact.Export()" id="btnExport">
                    <i class="fa fa-file-excel-o" id="icon-export" title="Xuất excel">
                    </i>
                </button>
            </div>
        </div>
        <div class="wrap_bg wrap_bg_no-padding mb20">
            <div class="table-responsive table-default">
                <table class="table table-nowrap  w-100">
                    <thead>
                        <tr>
                            <th class="text-center" style="width: 0;">
                                <div class="flex flex-nowrap">
                                    <label class="check-list mb-3">
                                        <input type="checkbox">
                                        <span class="checkmark"></span>
                                    </label>
                                </div>
                            </th>
                            <th style="width: 15%">Số điện thoại</th>
                            <th style="width: 15%">Email</th>
                            <th style="width: 60%">Lời nhắn</th>
                        </tr>
                    </thead>
                    <tbody id="client-contact-list">
                       
                    </tbody>
                </table>
            </div>
            <div class="bottom-action flex flex-nowrap gap10 justify-content-end mt-3">
                <button class="btn btn-default white" style="padding: 0 10px;">
                    <i class="icofont-gear"></i>
                    <span>Tùy chỉnh</span>
                </button>
                <div class="form-group select-icon">
                    <select id="item-per-page" class="select2" name="">
                        <option value="50">Hiển thị 50 kết quả/trang</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                        <option value="200">200</option>
                    </select>
                </div>
            </div>
        </div>

    </div>
</section>

@section Scripts {
    <script src="/modules/client_contact.js"></script>
}