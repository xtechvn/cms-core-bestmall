@{
    ViewData["Title"] = "Quản lý sản phẩm v2";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<section class="main-container main-products">
    <div class="row-main container bg-white" style="padding-top:5px;">
        <div class="line-bottom"  style="padding-bottom: 0;height: 35px;margin-top: 10px !important;">
            <div id="product-search-tab-container" class="tab-default mb0" data-tab-container="tab-container-1" style="height:25px;">
                <a href="javascript:;" data-status="-1" class="product-search-tab text-uppercase active">Tất cả sản phẩm  </a>
                <a href="javascript:;" data-status="4" class="product-search-tab text-uppercase">Sản phẩm chờ duyệt</a>
                <a href="javascript:;" data-status="1" class="product-search-tab text-uppercase">Sản phẩm Đã duyệt / Đang hoạt động </a>
                <a href="javascript:;" data-status="2" class="product-search-tab text-uppercase">Sản phẩm đã ẩn / Ngưng hoạt động</a>
            </div>
        </div>
        <div class="flex gap10 flex-lg-nowrap">
            <div class="form-group w-100 ">
                <div class="search-wrapper">
                    <input id="input-search-product-name" type="text" class="input_search  onclick-togle border" name="" value="" style="height:40px;"
                           placeholder="Từ khoá, mã sản phẩm,...">
                    <span class="search-btn">
                        <button class="btn-search-product" type="submit">
                            <svg class="icon-svg">
                                <use xlink:href="images/icons/icon.svg#search"></use>
                            </svg>
                        </button>
                    </span>
                </div>
            </div>
            <div class="form-group w-100 ">
                <div class="search-wrapper">
                    <select id="search-group" class="select2 w-100" style="width:100% !important;" placeholder="Tìm kiếm theo ngành hàng">
                    </select>
                   @*  <span class="search-btn">
                        <button class="btn-search-product" type="submit">
                            <svg class="icon-svg">
                                <use xlink:href="images/icons/icon.svg#search"></use>
                            </svg>
                        </button>
                    </span> *@
                </div>
            </div>
            <div class="form-group"> 
                <button id="btn-search-product-clear-search" class="btn btn-round" style=" height: 40px; "> Xóa bộ lọc </button>
            </div>
            <div class="form-group">
                <button class="btn select-icon btn-round btn-outline-secondary btn-search-product" style="height:40px;">
                    <i class="icofont-search"></i>
                    Tìm kiếm
                </button>
            </div>
        </div>
        <div class="flex gap10 flex-lg-nowrap justify-content-between mb-3 align-items-center">
            <div class="flex gap10">
                <h5 class="m-0"><nw id="count-product" class="count"data-value="@ViewBag.CountSp">@ViewBag.CountSp</nw> sản phẩm</h5>
                @*<span class="hanmuc">
                Hạn mức đăng bán
                <i class="icofont-info-circle"></i>
                </span>*@
            </div>
            <div class="flex gap10">
                <button id="export-excel" class="btn btn-round btn-export-excel">
                    <i id="icon-export" class="icofont-file-excel"></i>Xuất Excel
                </button> 
                <button class="btn btn-round product-import">
                   Công cụ xử lý hàng loạt
                    <div class="box-action" style="right:auto;bottom:auto;z-index: 1; display:none;">
                        <a href="javascript:;" class="product-import-add">Đăng hàng loạt</a>
                        <a href="javascript:;">Cập nhật hàng loạt</a>
                    </div>
                </button>
               
                <button class="btn btn-base btn-round btn-add-product">
                    <i class="icofont-plus "></i>Thêm sản phẩm mới
                </button>
            </div>
        </div>
        <div id="product_list" class="wrap_bg wrap_bg_no-padding mb20">
           
        </div>

    </div>
</section>

@section Scripts {
    <script src="/modules/product/common.js"></script>
    <script src="/modules/product/index.js"></script>
    <script src="/modules/product/import_excel.js"></script>
}