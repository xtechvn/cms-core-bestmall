@using Entities.ViewModels
@{
    ViewData["Title"] = "Danh sách thương hiệu";
}
<div class="row-main container">
    <h2 class="txt_18 bold mb20">Danh sách thương hiệu</h2>
    <div class="flex fillter-donhang">
        <div class="form-group mb10 mr-2">
            <input type="text" class="form-control" id="search-name" placeholder="Tên thương hiệu" style="width: 150px;">
        </div>
        <div class="form-group mb10 mr-2">
            <input type="text" class="form-control" id="search-code" placeholder="Mã thương hiệu" style="width: 150px;">
        </div>
        <div class="form-group mb10 mr-2">
            <select class="select2" name="" id="search-status" placeholder="Trạng thái hoạt động" style="width: 150px;">
                <option value="-1">Tất cả trạng thái</option>
                <option value="1">Hoạt động</option>
                <option value="2">Tạm ngưng</option>
            </select>
        </div>
       
        <div class="mb10 mr-2">
            <a href="javascript:;" class="btn btn-default bg-main mb10" onclick="label_service.Update(0);"><i class="fa fa-plus"></i>Thêm thương hiệu mới</a>
            @* <button class="btn-search btn-default " type="button" onclick="label_service.Export()" id="btnExport">
                <i class="fa fa-file-excel-o" id="icon-export"></i>
            </button> *@
            <a href="javascript:;" class="btn btn-default bg-main mb10" onclick="label_service.OnSearch()" style=" color: white;">
                <svg class="icon-svg" style="vertical-align: sub;">
                    <use xlink:href="/images/icons/icon.svg#search"></use>
                </svg>
                Tìm kiếm
            </a>
        </div>
    </div>
    <div class="tab-default" style="border-bottom: 1px solid #CCCCCC;">
        <a href="javascript:;" class="active">Tất cả (<nw class="count">0</nw>)</a>
@*         <a href="#">Đang xử lý (15)</a>
        <a href="#">Thanh toán thiếu (0)</a>
        <a href="#">Từ chối (5)</a>
        <a href="#">Thành công (30)</a> *@
    </div>

    <div id="grid_data" class="wrap_bg wrap_bg_no-padding mb20 placeholder">
       
    </div>


</div>
@section scripts {
    <script type="text/javascript" src="~/modules/label/index.js"></script>
    <script type="text/javascript" src="~/modules/label/detail.js"></script>
}